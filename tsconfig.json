{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"jsxImportSource": "astro",
		"strictNullChecks": true,
		"allowJs": false,
		"declaration": true,
		"skipLibCheck": true,
		"plugins": [
			{
				"name": "@astrojs/ts-plugin"
			}
		],
		"paths": {
			"@components/*": ["./src/components/*"],
			"@assets/*": ["./src/assets/*"],
			"@constants/*": ["./src/constants/*"],
			"@utils/*": ["./src/utils/*"],
			"@i18n/*": ["./src/i18n/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@/*": ["./src/*"],
			"src/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"]
}
