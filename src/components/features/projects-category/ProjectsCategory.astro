---
import { ProjectCard } from "../projects";
import { SectionTitle } from "../section-title";
import type { ProjectsCategoryProps } from "./types";

const {
	projects,
	category,
	categoryText,
	class: className = "",
} = Astro.props as ProjectsCategoryProps;
---

<div class={`projects-category-section ${className}`} data-category={category}>
	<SectionTitle title={categoryText} count={projects.length} />
	<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
		{
			projects.map((project) => (
				<ProjectCard
					project={project}
					size="medium"
					showImage={true}
					maxTechStack={3}
				/>
			))
		}
	</div>
</div>
