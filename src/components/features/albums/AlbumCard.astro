---
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import I18nKey from "../../../i18n/i18nKey";
import type { AlbumCardProps } from "./types";

const { album } = Astro.props as AlbumCardProps;
---

<a
	href={`/albums/${album.id}/`}
	data-tags={album.tags?.join(",") || ""}
	class="album-card group relative block overflow-hidden rounded-xl transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
>
	<!-- Cover Image -->
	<div class="aspect-4/3 relative overflow-hidden">
		{
			album.cover ? (
				<img
					src={album.cover}
					alt={album.title}
					class="w-full h-full object-cover pointer-events-none transition-transform duration-500 group-hover:scale-105"
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div class="w-full h-full bg-(--btn-regular-bg) flex items-center justify-center">
					<Icon
						name="material-symbols:photo-library"
						class="text-5xl text-black/20 dark:text-white/20"
					/>
				</div>
			)
		}

		<!-- Photo count badge -->
		<div
			class="absolute top-2 right-2 flex items-center gap-1.5"
		>
			{
				album.password && (
					<div class="px-2 py-1 rounded-full text-xs text-white font-medium bg-black/50 backdrop-blur-sm flex items-center gap-1">
						<svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
							<path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
						</svg>
					</div>
				)
			}
			<div class="px-2 py-1 rounded-full text-xs text-white font-medium bg-black/50 backdrop-blur-sm">
				{album.photos.length}
				{i18n(I18nKey.albumsPhotosCount)}
			</div>
		</div>

		<!-- Gradient overlay + info -->
		<div
			class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"
		>
		</div>
		<div class="absolute bottom-0 left-0 right-0 p-4">
			<h3
				class="font-bold text-base text-white line-clamp-1 drop-shadow-lg"
			>
				{album.title}
			</h3>

			{
				album.description && (
					<p
						class="text-xs text-white/75 line-clamp-1 mt-1 leading-relaxed"
						title={album.description}
					>
						{album.description}
					</p>
				)
			}

			<div
				class="flex items-center gap-3 text-xs text-white/70 mt-1.5 flex-wrap"
			>
				{
					album.date && (
						<span>
							{new Date(album.date).toLocaleDateString("zh-CN")}
						</span>
					)
				}
				{
					album.location && (
						<span class="inline-flex items-center gap-0.5">
							<svg
								class="w-3 h-3"
								viewBox="0 0 24 24"
								fill="currentColor"
							>
								<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z" />
							</svg>
							{album.location}
						</span>
					)
				}
			</div>

			{
				album.tags && album.tags.length > 0 && (
					<div class="flex flex-wrap gap-1 mt-2">
						{album.tags.slice(0, 4).map((tag: string) => (
							<span class="text-[0.6rem] px-1.5 py-0.5 rounded bg-white/20 text-white/90 backdrop-blur-sm">
								{tag}
							</span>
						))}
					</div>
				)
			}
		</div>
	</div>
</a>

<style>
	.album-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
	}

	.album-card.filtered-out {
		display: none;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.album-card:nth-child(1) {
		animation-delay: 0.03s;
	}
	.album-card:nth-child(2) {
		animation-delay: 0.06s;
	}
	.album-card:nth-child(3) {
		animation-delay: 0.09s;
	}
	.album-card:nth-child(4) {
		animation-delay: 0.12s;
	}
	.album-card:nth-child(5) {
		animation-delay: 0.15s;
	}
	.album-card:nth-child(6) {
		animation-delay: 0.18s;
	}
	.album-card:nth-child(7) {
		animation-delay: 0.21s;
	}
	.album-card:nth-child(8) {
		animation-delay: 0.24s;
	}
	.album-card:nth-child(9) {
		animation-delay: 0.27s;
	}
	.album-card:nth-child(10) {
		animation-delay: 0.3s;
	}
	.album-card:nth-child(11) {
		animation-delay: 0.33s;
	}
	.album-card:nth-child(12) {
		animation-delay: 0.36s;
	}

	.line-clamp-1 {
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
