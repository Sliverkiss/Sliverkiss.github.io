---
import AnimeCard from "./AnimeCard.astro";

interface StatusInfo {
	text: string;
	class: string;
	icon: string;
}

interface AnimeItem {
	title: string;
	cover: string;
	link: string;
	status: string;
	rating: number;
	progress: number;
	totalEpisodes: number;
	description: string;
	year: string;
	studio: string;
	genre: string[];
}

interface Props {
	visibleAnimeList: AnimeItem[];
	hiddenAnimeList: AnimeItem[];
	statusMap: Record<string, StatusInfo>;
	yearLabel: string;
	studioLabel: string;
}

const { visibleAnimeList, hiddenAnimeList, statusMap, yearLabel, studioLabel } =
	Astro.props;

const hasHiddenItems = hiddenAnimeList.length > 0;
---

<div
	id="anime-list-container"
	class="anime-grid-container grid gap-4 md:gap-6 opacity-0 transition-opacity duration-300"
>
	{
		visibleAnimeList.map((anime) => {
			const statusInfo = statusMap[anime.status] || {
				text: anime.status,
				class: "btn-regular",
				icon: "?",
			};
			return (
				<AnimeCard
					anime={anime}
					statusInfo={statusInfo}
					yearLabel={yearLabel}
					studioLabel={studioLabel}
				/>
			);
		})
	}
</div>

<template id="anime-lazy-store">
	{
		hiddenAnimeList.map((anime) => {
			const statusInfo = statusMap[anime.status] || {
				text: anime.status,
				class: "btn-regular",
				icon: "?",
			};
			return (
				<AnimeCard
					anime={anime}
					statusInfo={statusInfo}
					yearLabel={yearLabel}
					studioLabel={studioLabel}
				/>
			);
		})
	}
</template>

{
	hasHiddenItems && (
		<div
			id="infinite-scroll-sentinel"
			class="w-full h-20 flex items-center justify-center mt-8"
		>
			<div class="anime-loading-spinner w-8 h-8 border-4 border-[var(--primary)] border-t-transparent rounded-full animate-spin" />
		</div>
	)
}
