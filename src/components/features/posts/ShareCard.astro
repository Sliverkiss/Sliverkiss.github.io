---
import SharePoster from "@components/misc/SharePoster.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { Icon } from "astro-icon/components";
import { profileConfig } from "src/config";

interface Props {
	title: string;
	description?: string;
	author?: string;
	pubDate: string;
	coverImage?: string;
	url: string;
	siteTitle: string;
	avatar?: string;
	class?: string;
}

const {
	title,
	description,
	author = profileConfig.name,
	pubDate,
	coverImage,
	url,
	siteTitle,
	avatar,
	class: className,
} = Astro.props;

const finalAuthor = author || profileConfig.name;
---

<div
	class:list={[
		"p-6 bg-(--license-block-bg) rounded-xl mb-6 onload-animation",
		className,
	]}
>
	<div class="flex flex-col sm:flex-row items-center justify-between gap-4">
		<div class="flex items-center gap-3 flex-1">
			<div
				class="flex items-center justify-center h-12 w-12 rounded-lg bg-(--enter-btn-bg)"
			>
				<Icon
					name="material-symbols:share"
					class="text-3xl text-(--primary)"
				/>
			</div>
			<div class="flex flex-col gap-1">
				<div
					class="text-[1.0rem] leading-tight text-black/75 dark:text-white/75"
				>
					{i18n(I18nKey.shareOnSocial)}
				</div>
				<p
					class="text-[0.8rem] leading-tight text-black/75 dark:text-white/75"
				>
					{i18n(I18nKey.shareOnSocialDescription)}
				</p>
			</div>
		</div>
		<div class="flex items-center gap-3">
			<SharePoster
				client:visible
				{title}
				author={finalAuthor}
				description={description || ""}
				{pubDate}
				coverImage={coverImage ?? null}
				{url}
				{siteTitle}
				avatar={avatar ?? null}
			/>
		</div>
	</div>
</div>
