---
import type { LoaderProps } from "./types";

const {
	size = "md",
	variant = "spinner",
	class: className = "",
}: LoaderProps = Astro.props;

const sizeClasses = {
	sm: "w-4 h-4",
	md: "w-6 h-6",
	lg: "w-8 h-8",
};
---

{
	variant === "spinner" && (
		<div class={`loader-spinner ${sizeClasses[size]} ${className}`.trim()}>
			<svg class="animate-spin" viewBox="0 0 24 24" fill="none">
				<circle
					class="opacity-25"
					cx="12"
					cy="12"
					r="10"
					stroke="currentColor"
					stroke-width="4"
				/>
				<path
					class="opacity-75"
					fill="currentColor"
					d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
				/>
			</svg>
		</div>
	)
}

{
	variant === "dots" && (
		<div class={`loader-dots flex space-x-1 ${className}`.trim()}>
			<div
				class="w-2 h-2 bg-current rounded-full animate-bounce"
				style="animation-delay: 0ms;"
			/>
			<div
				class="w-2 h-2 bg-current rounded-full animate-bounce"
				style="animation-delay: 150ms;"
			/>
			<div
				class="w-2 h-2 bg-current rounded-full animate-bounce"
				style="animation-delay: 300ms;"
			/>
		</div>
	)
}

{
	variant === "pulse" && (
		<div class={`loader-pulse ${sizeClasses[size]} ${className}`.trim()}>
			<div class="w-full h-full bg-current rounded-full animate-pulse" />
		</div>
	)
}

<style>
	.loader-spinner {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
	}

	.loader-dots {
		align-items: center;
	}
</style>
