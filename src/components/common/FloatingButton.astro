---
import { Icon } from "astro-icon/components";

interface Props {
	id: string;
	icon: string;
	ariaLabel?: string;
	onclick?: string;
	class?: string;
}

const { id, icon, ariaLabel, onclick, class: className = "" } = Astro.props;
---

<div
	id={id}
	class:list={[
		"floating-btn",
		className,
		"btn-card flex items-center rounded-2xl overflow-hidden transition",
	]}
	onclick={onclick}
>
	<button aria-label={ariaLabel} class="h-full w-full rounded-2xl">
		<Icon name={icon} class="mx-auto" />
	</button>
</div>

<style lang="stylus">
.floating-btn
	color: var(--primary)
	font-size: 1.5rem
	font-weight: bold
	width: 3rem
	height: 3rem
	opacity: 1
	cursor: pointer
	pointer-events: auto
	transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1)
	border-radius: 1rem
	border: 1px solid rgba(148, 163, 184, 0.45)
	flex-shrink: 0
	overflow: hidden

	:global(svg)
		font-size: 1.6rem
		opacity: 1
		transition: opacity 0.2s ease 0.1s

	&.hide
		transform: scale(0.5)
		opacity: 0
		pointer-events: none
		height: 0 !important
		width: 0 !important
		margin: 0 !important
		border-width: 0 !important
		padding: 0 !important

		:global(svg)
			opacity: 0
			transition: opacity 0.1s ease

	&:active
		transform: scale(0.9)

	&:hover
		color: var(--primary)
		box-shadow: var(--shadow-button)

	&.active
		background: var(--btn-card-bg-active)

:global(.dark) .floating-btn
	border: 1px solid rgba(255, 255, 255, 0.15)
	color: var(--primary, #60a5fa)

	&:hover
		color: var(--primary)
		box-shadow: var(--shadow-button-dark)

@media (max-width: 768px)
	.floating-btn
		width: 2.75rem
		height: 2.75rem
		font-size: 1.4rem
		border-radius: 0.75rem

		:global(svg)
			font-size: 1.4rem

@media (max-width: 480px)
	.floating-btn
		width: 2.5rem
		height: 2.5rem
		font-size: 1.25rem
		border-radius: 0.5rem

		:global(svg)
			font-size: 1.2rem

.floating-btn
	min-width: 0
	min-height: 0
	padding: 0.25rem

	&.hide
		padding: 0
</style>
