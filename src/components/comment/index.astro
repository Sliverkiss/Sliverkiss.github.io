---
import type { CollectionEntry } from "astro:content";

import { commentConfig } from "@/config";
import { removeFileExtension } from "@/utils/url-utils";

import Giscus from "./Giscus.astro";
import Twikoo from "./Twikoo.astro";

interface Props {
	post?: CollectionEntry<"posts">;
	path?: string;
}

const { post, path: customPath } = Astro.props as Props;

const path = post
	? `/posts/${removeFileExtension(post.id)}`
	: (customPath ?? "");
// const url = `${Astro.site?.href}${path}`;

let commentService = "";
if (commentConfig?.enable) {
	if (commentConfig.system) {
		commentService = commentConfig.system;
	} else if (commentConfig.twikoo) {
		commentService = "twikoo";
	}
}

const commentEnabled = post ? (post.data.comment ?? true) : true;
---

{
	commentConfig?.enable && commentEnabled && path && (
		<div class="card-base p-6 mb-4">
			{commentService === "twikoo" && <Twikoo path={path} />}
			{commentService === "giscus" && <Giscus path={path} />}
			{commentService === "" && null}
		</div>
	)
}
