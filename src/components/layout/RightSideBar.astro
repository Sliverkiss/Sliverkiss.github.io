---
import type { MarkdownHeading } from "astro";

import SidebarColumn from "@/components/layout/SidebarColumn.astro";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
}

const { class: className, headings } = Astro.props;
---

<SidebarColumn
	side="right"
	containerId="right-sidebar"
	stickyId="right-sidebar-sticky"
	rootClass={`${className ?? ""} w-full`}
	headings={headings}
	showMobile={false}
	showTablet={false}
	showDesktop={true}
/>
